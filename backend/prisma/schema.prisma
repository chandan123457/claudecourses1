// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @map("firebase_uid")
  phone       String
  name        String
  email       String   @unique
  role        String   @default("student")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders                       Order[]
  courseEnrollments            CourseEnrollment[]
  webinarRegistrations         WebinarRegistration[]
  profile                      UserProfile?
  programEnrollments           ProgramEnrollment[]
  certifications               Certification[]
  mockInterviews               MockInterview[]
  interviewBookings            InterviewBooking[]
  portalEligibility            PortalEligibility?
  skillBadges                  SkillBadge[]
  lessonProgress               LessonProgress[]
  programOrders                ProgramOrder[]
  certificationEnrollments     CertificationEnrollment[]
  certificationOrders          CertificationOrder[]
  certificationSubmissions     CertificationSubmission[]
  certificationBookings        CertificationMentorBooking[]
  projectCertificates          ProjectCertificate[]
  programAssignmentSubmissions ProgramAssignmentSubmission[]
  programAssignmentComments    ProgramAssignmentComment[]

  @@map("users")
}

model Webinar {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  description String
  teacher     String
  date        DateTime @db.Date
  time        String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  registrations WebinarRegistration[]

  @@map("webinars")
}

model Course {
  id           Int      @id @default(autoincrement())
  title        String
  image        String
  description  String
  syllabus     String
  teacher      String
  price        Int
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  telegramLink String?  @map("telegram_link")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders      Order[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model Order {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  courseId        Int      @map("course_id")
  razorpayOrderId String   @unique @map("razorpay_order_id")
  amount          Int
  currency        String   @default("INR")
  status          String   @default("created")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment    Payment?
  enrollment CourseEnrollment?

  @@map("orders")
}

model Payment {
  id                Int      @id @default(autoincrement())
  orderId           Int      @unique @map("order_id")
  razorpayPaymentId String   @unique @map("razorpay_payment_id")
  razorpaySignature String   @map("razorpay_signature")
  status            String   @default("success")
  paidAt            DateTime @default(now()) @map("paid_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model CourseEnrollment {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  courseId   Int      @map("course_id")
  orderId    Int      @unique @map("order_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

model WebinarRegistration {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  webinarId    Int      @map("webinar_id")
  registeredAt DateTime @default(now()) @map("registered_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([userId, webinarId])
  @@map("webinar_registrations")
}

// ============================================================
// DASHBOARD / PLACEMENT PLATFORM MODELS
// ============================================================

model UserProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique @map("user_id")
  avatar            String?
  bio               String?  @db.Text
  location          String?
  education         String?
  githubUrl         String?  @map("github_url")
  linkedinUrl       String?  @map("linkedin_url")
  githubConnected   Boolean  @default(false) @map("github_connected")
  linkedinConnected Boolean  @default(false) @map("linkedin_connected")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Program {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  domain      String
  level       String
  duration    String
  thumbnail   String?
  instructor  String
  price       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  enrollments    ProgramEnrollment[]
  certifications Certification[]
  modules        ProgramModule[]
  orders         ProgramOrder[]

  @@map("programs")
}

model ProgramModule {
  id          Int      @id @default(autoincrement())
  programId   Int      @map("program_id")
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  isLocked    Boolean  @default(false) @map("is_locked")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  program               Program                       @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons               ProgramLesson[]
  assignment            ProgramAssignment?
  assignmentSubmissions ProgramAssignmentSubmission[]
  assignmentComments    ProgramAssignmentComment[]

  @@map("program_modules")
}

model ProgramLesson {
  id           Int      @id @default(autoincrement())
  moduleId     Int      @map("module_id")
  title        String
  description  String?  @db.Text
  duration     String?
  videoUrl     String?  @map("video_url")
  videoUrl360p String?  @map("video_url_360p")
  videoUrl480p String?  @map("video_url_480p")
  videoUrl720p String?  @map("video_url_720p")
  order        Int      @default(0)
  resources    Json?
  keyTakeaway  String?  @map("key_takeaway") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  module   ProgramModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@map("program_lessons")
}

model ProgramAssignment {
  id                Int       @id @default(autoincrement())
  moduleId          Int       @unique @map("module_id")
  title             String
  description       String    @db.Text
  dueDate           DateTime? @map("due_date")
  allowFileUpload   Boolean   @default(true) @map("allow_file_upload")
  allowGithubLink   Boolean   @default(false) @map("allow_github_link")
  allowResubmission Boolean   @default(false) @map("allow_resubmission")
  isEnabled         Boolean   @default(true) @map("is_enabled")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  module      ProgramModule                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions ProgramAssignmentSubmission[]
  comments    ProgramAssignmentComment[]

  @@map("program_assignments")
}

model ProgramAssignmentSubmission {
  id           Int      @id @default(autoincrement())
  assignmentId Int      @map("assignment_id")
  moduleId     Int      @map("module_id")
  userId       Int      @map("user_id")
  fileUrl      String?  @map("file_url")
  fileName     String?  @map("file_name")
  githubLink   String?  @map("github_link")
  status       String   @default("submitted")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignment ProgramAssignment          @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  module     ProgramModule              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments   ProgramAssignmentComment[]

  @@index([assignmentId, userId])
  @@index([moduleId])
  @@index([userId])
  @@map("program_assignment_submissions")
}

model ProgramAssignmentComment {
  id           Int      @id @default(autoincrement())
  submissionId Int      @map("submission_id")
  assignmentId Int      @map("assignment_id")
  moduleId     Int      @map("module_id")
  userId       Int      @map("user_id")
  comment      String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  submission ProgramAssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  assignment ProgramAssignment           @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  module     ProgramModule               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([assignmentId, userId])
  @@index([moduleId])
  @@map("program_assignment_comments")
}

model LessonProgress {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  lessonId  Int      @map("lesson_id")
  completed Boolean  @default(false)
  watchedAt DateTime @default(now()) @map("watched_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson ProgramLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model ProgramOrder {
  id              Int       @id @default(autoincrement())
  userId          Int?      @map("user_id")
  programId       Int       @map("program_id")
  razorpayOrderId String    @unique @map("razorpay_order_id")
  amount          Int
  currency        String    @default("INR")
  status          String    @default("created")
  claimToken      String?   @unique @map("claim_token")
  claimedAt       DateTime? @map("claimed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  payment ProgramPayment?

  @@map("program_orders")
}

model ProgramPayment {
  id                Int      @id @default(autoincrement())
  orderId           Int      @unique @map("order_id")
  razorpayPaymentId String   @unique @map("razorpay_payment_id")
  razorpaySignature String   @map("razorpay_signature")
  status            String   @default("success")
  paidAt            DateTime @default(now()) @map("paid_at")

  order ProgramOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("program_payments")
}

model ProgramEnrollment {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  programId     Int      @map("program_id")
  progress      Int      @default(0) // 0–100
  status        String   @default("active") // "active" | "completed" | "paused"
  currentModule String?  @map("current_module")
  enrolledAt    DateTime @default(now()) @map("enrolled_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("program_enrollments")
}

model Certification {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  programId      Int?     @map("program_id")
  title          String
  issuedBy       String   @map("issued_by")
  issuedAt       DateTime @map("issued_at")
  certificateUrl String?  @map("certificate_url")
  createdAt      DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@map("certifications")
}

model MockInterview {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  topic        String
  interviewer  String
  score        Float?
  rating       Float?
  feedback     String?  @db.Text
  strengths    String[] @default([])
  improvements String[] @default([])
  sessionDate  DateTime @map("session_date")
  type         String   @default("mock") // "mock" | "on_demand"
  status       String   @default("scheduled") // "scheduled" | "completed" | "cancelled"
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mock_interviews")
}

model InterviewBooking {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  domain        String
  preferredDate DateTime @map("preferred_date")
  status        String   @default("pending") // "pending" | "confirmed" | "cancelled"
  sessionLink   String?  @map("session_link")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interview_bookings")
}

model PortalEligibility {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  status         String   @default("not_qualified") // "qualified" | "not_qualified" | "pending"
  technicalScore Float    @default(0) @map("technical_score")
  softSkillScore Float    @default(0) @map("soft_skill_score")
  overallScore   Float    @default(0) @map("overall_score")
  eligibleTiers  String[] @default([]) @map("eligible_tiers")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_eligibility")
}

model SkillBadge {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  name     String
  category String // e.g. "Data Analysis", "System Design"
  earnedAt DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skill_badges")
}

model CertificationProject {
  id                  Int      @id @default(autoincrement())
  title               String
  slug                String   @unique
  domain              String
  difficulty          String
  durationWeeks       Int      @default(4) @map("duration_weeks")
  shortDescription    String   @map("short_description") @db.Text
  description         String   @db.Text
  thumbnail           String?
  bannerLabel         String?  @map("banner_label")
  tags                String[] @default([])
  eligibility         String   @default("Certification Eligible")
  basePrice           Int      @default(0) @map("base_price")
  platformFee         Int      @default(55) @map("platform_fee")
  popularScore        Int      @default(0) @map("popular_score")
  certificateEligible Boolean  @default(true) @map("certificate_eligible")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  plans        CertificationPlan[]
  sectionItems CertificationSectionItem[]
  mentors      CertificationMentor[]
  coupons      CertificationCoupon[]
  orders       CertificationOrder[]
  enrollments  CertificationEnrollment[]
  submissions  CertificationSubmission[]
  certificates ProjectCertificate[]

  @@map("certification_projects")
}

model CertificationPlan {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  name          String
  subtitle      String?
  durationLabel String   @map("duration_label")
  price         Int
  features      String[] @default([])
  isRecommended Boolean  @default(false) @map("is_recommended")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project     CertificationProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orders      CertificationOrder[]
  enrollments CertificationEnrollment[]

  @@map("certification_plans")
}

model CertificationSectionItem {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  sectionKey  String   @map("section_key")
  title       String
  description String   @db.Text
  stepNumber  Int?     @map("step_number")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project CertificationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("certification_section_items")
}

model CertificationMentor {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  name      String
  title     String
  avatarUrl String?  @map("avatar_url")
  bio       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  CertificationProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slots    CertificationMentorSlot[]
  bookings CertificationMentorBooking[]

  @@map("certification_mentors")
}

model CertificationMentorSlot {
  id        Int      @id @default(autoincrement())
  mentorId  Int      @map("mentor_id")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  status    String   @default("available")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mentor   CertificationMentor          @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  bookings CertificationMentorBooking[]

  @@map("certification_mentor_slots")
}

model CertificationCoupon {
  id           Int       @id @default(autoincrement())
  projectId    Int?      @map("project_id")
  code         String    @unique
  discountType String    @default("fixed") @map("discount_type")
  amount       Int
  minAmount    Int       @default(0) @map("min_amount")
  isActive     Boolean   @default(true) @map("is_active")
  expiresAt    DateTime? @map("expires_at")
  usageLimit   Int?      @map("usage_limit")
  usedCount    Int       @default(0) @map("used_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project CertificationProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  orders  CertificationOrder[]

  @@map("certification_coupons")
}

model CertificationOrder {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  projectId       Int      @map("project_id")
  planId          Int      @map("plan_id")
  couponId        Int?     @map("coupon_id")
  couponCode      String?  @map("coupon_code")
  basePrice       Int      @map("base_price")
  discount        Int      @default(0)
  platformFee     Int      @default(0) @map("platform_fee")
  totalAmount     Int      @map("total_amount")
  razorpayOrderId String   @unique @map("razorpay_order_id")
  currency        String   @default("INR")
  status          String   @default("created")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    CertificationProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plan       CertificationPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  coupon     CertificationCoupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  payment    CertificationPayment?
  enrollment CertificationEnrollment?

  @@map("certification_orders")
}

model CertificationPayment {
  id                Int      @id @default(autoincrement())
  orderId           Int      @unique @map("order_id")
  razorpayPaymentId String   @unique @map("razorpay_payment_id")
  razorpaySignature String   @map("razorpay_signature")
  status            String   @default("success")
  paidAt            DateTime @default(now()) @map("paid_at")

  order CertificationOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("certification_payments")
}

model CertificationEnrollment {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  projectId     Int      @map("project_id")
  planId        Int      @map("plan_id")
  orderId       Int?     @unique @map("order_id")
  couponCode    String?  @map("coupon_code")
  paymentStatus String   @default("pending") @map("payment_status")
  status        String   @default("enrolled")
  basePrice     Int      @default(0) @map("base_price")
  discount      Int      @default(0)
  platformFee   Int      @default(0) @map("platform_fee")
  finalPayable  Int      @default(0) @map("final_payable")
  enrolledAt    DateTime @default(now()) @map("enrolled_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     CertificationProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plan        CertificationPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  order       CertificationOrder?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  submissions CertificationSubmission[]
  bookings    CertificationMentorBooking[]
  certificate ProjectCertificate?

  @@unique([userId, projectId])
  @@map("certification_enrollments")
}

model CertificationSubmission {
  id                  Int      @id @default(autoincrement())
  enrollmentId        Int      @map("enrollment_id")
  userId              Int      @map("user_id")
  projectId           Int      @map("project_id")
  attemptNumber       Int      @default(1) @map("attempt_number")
  designDocUrl        String?  @map("design_doc_url")
  designDocName       String?  @map("design_doc_name")
  requirementsDocUrl  String?  @map("requirements_doc_url")
  requirementsDocName String?  @map("requirements_doc_name")
  githubLink          String?  @map("github_link")
  demoLink            String?  @map("demo_link")
  status              String   @default("pending")
  marks               Int?
  reviewNotes         String?  @map("review_notes") @db.Text
  submittedAt         DateTime @default(now()) @map("submitted_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  enrollment  CertificationEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     CertificationProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluations CertificationEvaluation[]

  @@map("certification_submissions")
}

model CertificationEvaluation {
  id           Int      @id @default(autoincrement())
  submissionId Int      @map("submission_id")
  type         String
  feedback     String?  @db.Text
  status       String   @default("pending")
  score        Int?
  reviewerName String?  @map("reviewer_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  submission CertificationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("certification_evaluations")
}

model CertificationMentorBooking {
  id           Int      @id @default(autoincrement())
  enrollmentId Int      @map("enrollment_id")
  mentorId     Int      @map("mentor_id")
  slotId       Int      @map("slot_id")
  userId       Int      @map("user_id")
  status       String   @default("booked")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enrollment CertificationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  mentor     CertificationMentor     @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  slot       CertificationMentorSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slotId])
  @@map("certification_mentor_bookings")
}

model ProjectCertificate {
  id               Int      @id @default(autoincrement())
  enrollmentId     Int      @unique @map("enrollment_id")
  userId           Int      @map("user_id")
  projectId        Int      @map("project_id")
  title            String
  certificateUrl   String?  @map("certificate_url")
  verificationCode String   @unique @map("verification_code")
  issuedAt         DateTime @default(now()) @map("issued_at")
  createdAt        DateTime @default(now()) @map("created_at")

  enrollment CertificationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    CertificationProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_certificates")
}
