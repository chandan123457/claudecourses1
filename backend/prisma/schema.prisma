// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  firebaseUid     String   @unique @map("firebase_uid")
  phone           String
  name            String
  email           String   @unique
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  orders                Order[]
  courseEnrollments     CourseEnrollment[]
  webinarRegistrations  WebinarRegistration[]
  profile               UserProfile?
  programEnrollments    ProgramEnrollment[]
  certifications        Certification[]
  mockInterviews        MockInterview[]
  interviewBookings     InterviewBooking[]
  portalEligibility     PortalEligibility?
  skillBadges           SkillBadge[]
  lessonProgress        LessonProgress[]
  programOrders         ProgramOrder[]

  @@map("users")
}

model Webinar {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  description String
  teacher     String
  date        DateTime @db.Date
  time        String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  registrations WebinarRegistration[]

  @@map("webinars")
}

model Course {
  id            Int      @id @default(autoincrement())
  title         String
  image         String
  description   String
  syllabus      String
  teacher       String
  price         Int
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime @map("end_date") @db.Date
  telegramLink  String?  @map("telegram_link")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders        Order[]
  enrollments   CourseEnrollment[]

  @@map("courses")
}

model Order {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  courseId          Int      @map("course_id")
  razorpayOrderId   String   @unique @map("razorpay_order_id")
  amount            Int
  currency          String   @default("INR")
  status            String   @default("created")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment           Payment?
  enrollment        CourseEnrollment?

  @@map("orders")
}

model Payment {
  id                  Int      @id @default(autoincrement())
  orderId             Int      @unique @map("order_id")
  razorpayPaymentId   String   @unique @map("razorpay_payment_id")
  razorpaySignature   String   @map("razorpay_signature")
  status              String   @default("success")
  paidAt              DateTime @default(now()) @map("paid_at")

  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model CourseEnrollment {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  courseId   Int      @map("course_id")
  orderId    Int      @unique @map("order_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

model WebinarRegistration {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  webinarId    Int      @map("webinar_id")
  registeredAt DateTime @default(now()) @map("registered_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webinar      Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([userId, webinarId])
  @@map("webinar_registrations")
}

// ============================================================
// DASHBOARD / PLACEMENT PLATFORM MODELS
// ============================================================

model UserProfile {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique @map("user_id")
  avatar         String?
  bio            String?   @db.Text
  location       String?
  education      String?
  githubUrl      String?   @map("github_url")
  linkedinUrl    String?   @map("linkedin_url")
  githubConnected  Boolean @default(false) @map("github_connected")
  linkedinConnected Boolean @default(false) @map("linkedin_connected")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Program {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  domain      String
  level       String
  duration    String
  thumbnail   String?
  instructor  String
  price       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  enrollments      ProgramEnrollment[]
  certifications   Certification[]
  modules          ProgramModule[]
  orders           ProgramOrder[]

  @@map("programs")
}

model ProgramModule {
  id          Int      @id @default(autoincrement())
  programId   Int      @map("program_id")
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  isLocked    Boolean  @default(false) @map("is_locked")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  program     Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons     ProgramLesson[]

  @@map("program_modules")
}

model ProgramLesson {
  id            Int      @id @default(autoincrement())
  moduleId      Int      @map("module_id")
  title         String
  description   String?  @db.Text
  duration      String?
  videoUrl      String?  @map("video_url")
  videoUrl360p  String?  @map("video_url_360p")
  videoUrl480p  String?  @map("video_url_480p")
  videoUrl720p  String?  @map("video_url_720p")
  order         Int      @default(0)
  resources     Json?
  keyTakeaway   String?  @map("key_takeaway") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  module        ProgramModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress      LessonProgress[]

  @@map("program_lessons")
}

model LessonProgress {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  lessonId  Int      @map("lesson_id")
  completed Boolean  @default(false)
  watchedAt DateTime @default(now()) @map("watched_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    ProgramLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model ProgramOrder {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  programId         Int      @map("program_id")
  razorpayOrderId   String   @unique @map("razorpay_order_id")
  amount            Int
  currency          String   @default("INR")
  status            String   @default("created")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program           Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  payment           ProgramPayment?

  @@map("program_orders")
}

model ProgramPayment {
  id                  Int      @id @default(autoincrement())
  orderId             Int      @unique @map("order_id")
  razorpayPaymentId   String   @unique @map("razorpay_payment_id")
  razorpaySignature   String   @map("razorpay_signature")
  status              String   @default("success")
  paidAt              DateTime @default(now()) @map("paid_at")

  order               ProgramOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("program_payments")
}

model ProgramEnrollment {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  programId    Int      @map("program_id")
  progress     Int      @default(0)             // 0–100
  status       String   @default("active")      // "active" | "completed" | "paused"
  currentModule String? @map("current_module")
  enrolledAt   DateTime @default(now()) @map("enrolled_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("program_enrollments")
}

model Certification {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  programId   Int?     @map("program_id")
  title       String
  issuedBy    String   @map("issued_by")
  issuedAt    DateTime @map("issued_at")
  certificateUrl String? @map("certificate_url")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program     Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@map("certifications")
}

model MockInterview {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  topic       String
  interviewer String
  score       Float?
  rating      Float?
  feedback    String?  @db.Text
  strengths   String[] @default([])
  improvements String[] @default([])
  sessionDate DateTime @map("session_date")
  type        String   @default("mock")    // "mock" | "on_demand"
  status      String   @default("scheduled") // "scheduled" | "completed" | "cancelled"
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mock_interviews")
}

model InterviewBooking {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  domain        String
  preferredDate DateTime @map("preferred_date")
  status        String   @default("pending")  // "pending" | "confirmed" | "cancelled"
  sessionLink   String?  @map("session_link")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("interview_bookings")
}

model PortalEligibility {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  status          String   @default("not_qualified") // "qualified" | "not_qualified" | "pending"
  technicalScore  Float    @default(0) @map("technical_score")
  softSkillScore  Float    @default(0) @map("soft_skill_score")
  overallScore    Float    @default(0) @map("overall_score")
  eligibleTiers   String[] @default([]) @map("eligible_tiers")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_eligibility")
}

model SkillBadge {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  name      String
  category  String   // e.g. "Data Analysis", "System Design"
  earnedAt  DateTime @default(now()) @map("earned_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("skill_badges")
}